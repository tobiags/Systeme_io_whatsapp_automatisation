# ── Database (shared Postgres with the platform) ──────────────────────────────
POSTGRES_DSN=postgresql://platform:platform@db:5432/platform

# ── Wati ─────────────────────────────────────────────────────────────────────
WATI_API_URL=https://live-mt-server.wati.io/1116186
WATI_API_TOKEN=your_wati_bearer_token
WATI_CHANNEL_PHONE_NUMBER=          # optional, leave empty if not used

# ── OpenAI (même clé que la plateforme) ──────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Bot security ──────────────────────────────────────────────────────────────
BOT_API_KEY=your_secret_admin_key    # used for /admin/* endpoints (X-Bot-Key header)

# ── Behaviour ─────────────────────────────────────────────────────────────────
AUTO_REPLY_ENABLED=true
MAX_HISTORY_MESSAGES=10              # conversation turns fed to Claude
DEDUP_WINDOW_SECONDS=60             # ignore duplicate message within this window

# ── Closer notifications ──────────────────────────────────────────────────────
CLOSER_EMAIL=closer@yourdomain.com  # comma-separated for multiple recipients
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=bot@yourdomain.com
